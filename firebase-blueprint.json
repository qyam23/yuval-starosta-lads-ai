{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Inquiry": {
      "title": "Project Inquiry",
      "description": "Stores project inquiries submitted by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "reviewed", "contacted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "status", "createdAt"]
    },
    "AIHistory": {
      "title": "AI Lab History",
      "description": "Stores history of AI lab interactions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Project inquiries"
    },
    "/ai_history/{historyId}": {
      "schema": "AIHistory",
      "description": "AI interaction history"
    }
  }
}
